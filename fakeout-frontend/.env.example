# Backend WebSocket / REST URL
VITE_BACKEND_URL=http://localhost:3001

# Set to 'true' for Celo mainnet, omit or set to 'false' for Celo Sepolia testnet
VITE_MAINNET=false

# Deployed FakeoutGame contract address (update after each deployment)
# Testnet (Celo Sepolia):  deploy with `npm run deploy:celo-sepolia`
# Mainnet (Celo):         deploy with `npm run deploy:celo`
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# GoodDollar (G$) token address
# Celo Sepolia testnet: deploy MockERC20 via deploy script (no real G$ on Sepolia)
# Celo mainnet:         0x62b8B11039fCFE5AB0c56e502B1C372A3d372190
VITE_GOOD_DOLLAR_ADDRESS=0x0000000000000000000000000000000000000000

# GoodDollar UBI environment: 'production' (Celo mainnet) | 'staging' (testnet)
VITE_GOODDOLLAR_ENV=production

# Web3Auth Client ID — get from dashboard.web3auth.io
# Use Sapphire Devnet project for testnet, Sapphire Mainnet project for production
VITE_WEB3AUTH_CLIENT_ID=your_client_id_here
